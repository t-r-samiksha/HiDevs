# ============================================================
# Helm — Mastra Backend Environment Variables
# Copy to .env and fill in all values before running `mastra dev`.
# Never commit .env to source control.
# ============================================================

# ------------------------------------------------------------
# Supabase
# Dashboard → Settings → API
# Use SUPABASE_URL (no NEXT_PUBLIC_ prefix — server-side only)
# ------------------------------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ------------------------------------------------------------
# Google AI (Gemini)
# Used for gemini-embedding-001 (3072-dim) and gemini-2.5-flash.
# https://aistudio.google.com/app/apikey
# ------------------------------------------------------------
GOOGLE_GENERATIVE_AI_API_KEY=AIza...

# ------------------------------------------------------------
# Qdrant Vector Database
# Cluster URL and API key from Qdrant Cloud Console.
# Auth header: "api-key" (NOT "Authorization: Bearer").
# QDRANT_COLLECTION: override if your cluster added a timestamp
# suffix (e.g. meeting_items_1234567). Default: meeting_items.
# ------------------------------------------------------------
QDRANT_URL=https://your-cluster-id.region.aws.cloud.qdrant.io
QDRANT_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
QDRANT_COLLECTION=meeting_items

# ------------------------------------------------------------
# Enkrypt AI (Safety Guardrails — Checkpoints 1–4)
# Injection detection, adherence, relevancy, toxicity, PII.
# https://enkryptai.com
# ------------------------------------------------------------
ENKRYPT_API_KEY=your-enkrypt-api-key

# ------------------------------------------------------------
# Slack (Optional — reminder + weekly report notifications)
# Leave blank to disable. The workflows check for this at runtime.
# https://api.slack.com/messaging/webhooks
# ------------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
